# For Vercel + Vercel Postgres these are auto-injected.
# For local dev, run a Postgres locally and paste its URL here, or paste your Neon URL.
POSTGRES_PRISMA_URL="postgres://user:pass@host/db?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://user:pass@host/db"

JWT_SECRET="change-me-to-a-secure-32-char-string-in-production"
ANTHROPIC_API_KEY=""
APP_URL="http://localhost:3000"

# Razorpay (leave empty to use mock checkout)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
